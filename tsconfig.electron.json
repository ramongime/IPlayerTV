{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "outDir": "dist-electron",
    "strict": true,
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["node", "electron"],
    "paths": {
      "@shared/*": ["./src/shared/*"]
    },
    "skipLibCheck": true
  },
  "include": ["src/main/**/*.ts", "src/shared/**/*.ts"]
}
