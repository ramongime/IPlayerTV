{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "outDir": "../dist-scripts",
    "rootDir": "..",
    "strict": true,
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "paths": {
      "@iplayertv/core": ["../packages/core/src"]
    },
    "types": ["node"],
    "skipLibCheck": true
  },
  "include": ["./verify-backend.ts", "./verify-performance.ts"]
}
