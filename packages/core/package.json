{
  "name": "@iplayertv/core",
  "version": "0.1.0",
  "private": true,
  "description": "Shared domain, Xtream/TMDB providers and contracts for IPlayerTV desktop and mobile apps.",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/cjs/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.esm.json",
    "dev": "concurrently -k \"tsc -w -p tsconfig.json\" \"tsc -w -p tsconfig.esm.json\""
  },
  "dependencies": {
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.8.2"
  }
}
