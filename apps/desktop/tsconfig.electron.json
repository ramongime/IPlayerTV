{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "outDir": "dist-electron",
    "rootDir": "src",
    "baseUrl": ".",
    "strict": true,
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["node", "electron"],
    "skipLibCheck": true
  },
  "include": ["src/main/**/*.ts"]
}
